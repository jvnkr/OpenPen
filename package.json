{
  "name": "open-pen",
  "productName": "OpenPen",
  "version": "0.2.0",
  "description": "A free and open source on-screen annotation tool for Windows.",
  "license": "MIT",
  "author": "OpenPen contributors",
  "keywords": [
    "annotation",
    "screen-annotation",
    "whiteboard",
    "electron",
    "overlay",
    "presentation",
    "screencast",
    "windows"
  ],
  "homepage": "https://github.com/jvnkr/openpen#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvnkr/openpen.git"
  },
  "bugs": {
    "url": "https://github.com/jvnkr/openpen/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "pnpm icons && concurrently -k \"vite\" \"tsc -p tsconfig.electron.json && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "pnpm icons && tsc -p tsconfig.electron.json && vite build",
    "start": "pnpm run build && electron .",
    "dist": "pnpm run build && electron-builder",
    "release": "pnpm run build && electron-builder --publish always",
    "icons": "node scripts/gen-icon.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "perfect-freehand": "^1.2.3",
    "react": "^19.1.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "dev.openpen.app",
    "productName": "OpenPen",
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/icon.png",
      "build/icon.ico",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jvnkr",
        "repo": "openpen",
        "releaseType": "release"
      }
    ]
  }
}
